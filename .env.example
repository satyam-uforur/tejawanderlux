
# MongoDB Atlas Connection
# Get your MongoDB Atlas URI from: https://www.mongodb.com/cloud/atlas
# 1. Create a free cluster on MongoDB Atlas
# 2. Click "Connect" and select "Connect your application"
# 3. Copy the connection string
# 4. Replace PASSWORD with your database password
# 5. Replace DATABASE_NAME with your database name
# 6. Paste the full URI below

MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority

# Optional: Add other environment variables here
NEXT_PUBLIC_API_URL=http://localhost:3000
